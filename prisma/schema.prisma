generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // ADMIN | USER
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  attempts      Attempt[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Quiz Models
model Category {
  id      String   @id @default(cuid())
  name    String
  slug    String   @unique
  quizzes Quiz[]
}

model Quiz {
  id             String     @id @default(cuid())
  title          String
  categoryId     String
  category       Category   @relation(fields: [categoryId], references: [id])
  totalQuestions Int        @default(50)
  published      Boolean    @default(false)
  questions      Question[]
  attempts       Attempt[]
  createdAt      DateTime   @default(now())
}

enum Difficulty {
  LOW
  MEDIUM
  HIGH
}

model Question {
  id             String          @id @default(cuid())
  quizId         String
  quiz           Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  difficulty     Difficulty
  questionText   String          @db.Text
  options        Json            // ["A", "B", "C", "D"]
  correctIndex   Int
  explanation    String?         @db.Text
  sourceRef      String?
  attemptAnswers AttemptAnswer[]
}

model Attempt {
  id             String          @id @default(cuid())
  userId         String?
  user           User?           @relation(fields: [userId], references: [id])
  guestSessionId String?         // For anonymous users before Q5 gating
  quizId         String
  quiz           Quiz            @relation(fields: [quizId], references: [id])
  startedAt      DateTime        @default(now())
  finishedAt     DateTime?
  totalAttempted Int             @default(0)
  totalCorrect   Int             @default(0)
  timeTakenSec   Int             @default(0)
  mode           String          // category-wise | mix | difficulty-only
  difficultyMode String?         // low | medium | high | mixed
  scoreFinal     Float           @default(0.0)
  answers        AttemptAnswer[]
}

model AttemptAnswer {
  id           String   @id @default(cuid())
  attemptId    String
  attempt      Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question @relation(fields: [questionId], references: [id])
  selectedIndex Int
  isCorrect    Boolean
  timeSpentSec Int
}

model LeaderboardCache {
  id         String   @id @default(cuid())
  scope      String   // GLOBAL | QUIZ | CATEGORY
  scopeId    String?
  computedAt DateTime @default(now())
  topRows    Json     // [{ rank, name, score, attempted, accuracy }]
}

model PrizeRule {
  id        String @id @default(cuid())
  scope     String // GLOBAL | QUIZ | CATEGORY
  rankStart Int
  rankEnd   Int
  prizeText String
  active    Boolean @default(true)
}
